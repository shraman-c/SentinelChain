# Cloudflare Pages configuration
# Routes API requests to the Worker

/*
  X-Robots-Tag: noindex
</Content-Security-Policy>
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.cloudflareworkers.com https://*.workers.dev; img-src 'self' data:; font-src 'self'; worker-src 'self' blob:;
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Access-Control-Allow-Origin: *

/api/*
  Access-Control-Allow-Origin: *
